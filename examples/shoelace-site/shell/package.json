{
  "name": "trailhead-shoelace-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Example Trailhead shell with Shoelace design system",
  "scripts": {
    "start": "npm run build && vite preview --port 3001",
    "dev": "vite",
    "build": "vite build && npm run copy-shoelace",
    "copy-shoelace": "rm -rf dist/shoelace && mkdir -p dist/shoelace && cp -R node_modules/@shoelace-style/shoelace/cdn/* dist/shoelace/",
    "preview": "vite preview"
  },
  "dependencies": {
    "@herdingbits/trailhead-core": "^0.0.16",
    "@herdingbits/trailhead-shoelace": "^0.0.17"
  },
  "devDependencies": {
    "@herdingbits/trailhead-types": "^0.0.13",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "@shoelace-style/shoelace": "^2.20.1"
  }
}