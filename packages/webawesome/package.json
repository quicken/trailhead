{
  "name": "@herdingbits/trailhead-webawesome",
  "version": "0.1.2",
  "description": "Web Awesome web components adapter for Trailhead. Vanilla TypeScript, no React required.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shell.css": "./dist/shell.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && cp src/shell.css dist/"
  },
  "peerDependencies": {
    "@herdingbits/trailhead-core": "^0.1.0",
    "@awesome.me/webawesome": "^3.6.0"
  },
  "devDependencies": {
    "@herdingbits/trailhead-types": "^0.1.0",
    "@awesome.me/webawesome": "^3.10.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "micro-frontend",
    "webawesome",
    "web-awesome",
    "adapter",
    "trailhead"
  ],
  "author": "HerdingBits",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/quicken/trailhead.git",
    "directory": "packages/webawesome"
  }
}
